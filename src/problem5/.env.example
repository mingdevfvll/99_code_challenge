# =============================================================================
# Problem 5 — root environment
# Copy to .env. Used by docker-compose.yml.
# =============================================================================

# ----- Postgres -----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tasks
POSTGRES_PORT=5432

# ----- Redis -----
REDIS_PORT=6379

# ----- API -----
API_PORT=4000
NODE_ENV=production
LOG_LEVEL=info

# Connection strings consumed inside the api container.
# Hostnames are docker-compose service names, NOT localhost.
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/tasks
REDIS_URL=redis://redis:6379

# CORS allowlist for the API. Comma-separated for multiple origins.
WEB_ORIGIN=http://localhost:3000

# Rate limits (per IP per minute)
RATE_LIMIT_GLOBAL=100
RATE_LIMIT_MUTATIONS=30

# ----- Web -----
WEB_PORT=3000
# Browser-side fetches. Must be reachable from the user's machine, not the docker network.
NEXT_PUBLIC_API_URL=http://localhost:4000

# =============================================================================
# web/.env.example
# Copy to .env.local before `npm run dev`. Vars here are inlined into the
# client bundle at build time (Next.js NEXT_PUBLIC_* convention).
# =============================================================================

# URL the browser uses to reach the API. In dev this is the host-side address;
# inside docker compose (Phase 8) the api service answers on the same path.
NEXT_PUBLIC_API_URL=http://localhost:4000

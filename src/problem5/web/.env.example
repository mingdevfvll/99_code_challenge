# =============================================================================
# web/.env.example
# Copy to .env.local before `npm run dev`. Vars here are inlined into the
# client bundle at build time (Next.js NEXT_PUBLIC_* convention).
# =============================================================================

# URL the browser uses to reach the API. In Docker this is the host-side
# address, because browser requests do not use the Compose service network.
NEXT_PUBLIC_API_URL=http://localhost:4000

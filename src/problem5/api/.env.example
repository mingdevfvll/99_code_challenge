# =============================================================================
# api/.env.example
# Copy to .env when running the API outside Docker (npm run dev).
# When running inside docker compose, the root .env is used instead.
# =============================================================================

NODE_ENV=development
LOG_LEVEL=debug
API_PORT=4000

# Local-machine connection strings (note: localhost, not service names)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tasks
REDIS_URL=redis://localhost:6379

WEB_ORIGIN=http://localhost:3000

RATE_LIMIT_GLOBAL=100
RATE_LIMIT_MUTATIONS=30

NODE_ENV=test
LOG_LEVEL=silent
API_PORT=4001

# Test stack from docker-compose.test.yml — different ports than dev.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/tasks_test
REDIS_URL=redis://localhost:6380

WEB_ORIGIN=http://localhost:3000

# Higher than dev so the suite can hammer endpoints freely without tripping
# the limiter; one targeted test could lower these via override if needed.
RATE_LIMIT_GLOBAL=10000
RATE_LIMIT_MUTATIONS=10000
